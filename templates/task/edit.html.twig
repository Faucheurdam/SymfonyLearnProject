{% extends 'base.html.twig' %}

{% block title %}Modifier une tâche{% endblock %}

{% block body %}
    <h1>Modifier une tâche</h1>

    {{ form_start(form) }}
        {{ form_row(form.title) }}
        {{ form_row(form.description) }}

        <button type="submit">Enregistrer</button>
    {{ form_end(form) }}

    <p>
        <a href="{{ path('app_task_index') }}">Retour à la liste</a>
    </p>
{% endblock %}
