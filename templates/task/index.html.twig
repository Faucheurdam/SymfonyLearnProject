{% extends 'base.html.twig' %}

{% block title %}Liste des tâches{% endblock %}

{% block body %}
    {% for message in app.flashes('success') %}
        <div>{{ message }}</div>
    {% endfor %}

    <h1>Liste des tâches</h1>

    <p>
        <a href="{{ path('app_task_new') }}">Créer une tâche</a>
    </p>

    {% if tasks is empty %}
        <p>Aucune tâche pour le moment.</p>
    {% else %}
        <ul>
            {% for task in tasks %}
                <li>
                    <strong>{{ task.title }}</strong>

                    {% if task.description %}
                        <br>
                        {{ task.description }}
                    {% endif %}

                    <br>
                    Statut :
                    {% if task.isDone %}
                        Terminée
                    {% else %}
                        En cours
                    {% endif %}

                    <br>
                    Créée le : {{ task.createdAt|date('d/m/Y H:i') }}

                    <br>
                    <a href="{{ path('app_task_show', {id: task.id}) }}">Voir</a>
                    |
                    <a href="{{ path('app_task_edit', {id: task.id}) }}">Modifier</a>

                    <form method="post" action="{{ path('app_task_delete', {id: task.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette tâche ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_task_' ~ task.id) }}">
                        <button type="submit">Supprimer</button>
                    </form>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
